# LLM 服务的 Base URL，例如：
# https://api.openai.com/v1
# http://localhost:11434/v1
#
# 注意：
# 目前通常需要你自己确认并填写是否带 /v1。
# 如果服务端要求带 /v1，这里就需要手动写上。
GCS_BASEURL=

# 模型名称，例如：
# openai/gpt-4o-mini
# ollama/llama3
GCS_MODELNAME=

# 所选服务对应的 API Key。
GCS_APIKEY=

# 可选的重试次数，需为正整数。
GCS_MAX_RETRIES=3

# 可选的工作区根目录。
# 留空时使用项目根目录。
# 如果填写相对路径，会基于项目根目录解析。
GCS_WORKSPACE_DIR=
